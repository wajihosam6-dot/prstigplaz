# ─── Prestige Plaza Furniture — Environment Variables ───────
# Copy to .env.local and fill in your values

# ─── Site URL ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://prestigeplazafurniture.com

# ─── Google Maps (for live map embed) ────────────────────────
# Get a key from https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Analytics (optional) ────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=

# ─── Email / Contact Form (optional) ─────────────────────────
# e.g. Resend, SendGrid, EmailJS
RESEND_API_KEY=
CONTACT_EMAIL=info@prestigeplazafurniture.com

# ─── CMS (optional) ──────────────────────────────────────────
# Sanity, Contentful, Strapi, etc.
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=
